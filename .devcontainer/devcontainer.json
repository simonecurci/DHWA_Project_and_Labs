{
  "name": "Hardware Dev",
  "image": "ubuntu:jammy",
  "runArgs": [
    "--name",
    "hardware-dev",
    "--platform=linux/amd64"
  ],
  "remoteEnv": {
    "LANG": "C.UTF-8",
    "PATH": "/opt/riscv/bin:${containerEnv:PATH}"
  },
  "postCreateCommand": "./.devcontainer/post-create.sh",
  "customizations": {
    "vscode": {
      "extensions": [
        "mshr-h.veriloghdl",
        "ms-python.python",
        "ms-python.black-formatter",
        "ms-python.flake8"
      ]
    }
  }
}